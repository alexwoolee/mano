$color-screen-bg: #201E1D;
$color-surface: #272524;
$color-border: #595550;
$color-accent: #D38466;
$color-error: #C16A6A;
$color-orange: #d75f00 ;

Screen {
    background: $color-surface;
}

Header {
    background: $color-orange;
    text-align: center;
    content-align: center middle;
}

#main-screen {
    padding-bottom: 1;
    background: $color-surface;
}

/* Welcome Screen */
#welcome-screen {
    align: center middle;
    padding: 4;
}

#welcome-interface {
    background: $color-surface;
    border: wide white;
    align: center middle;
    width: 100%;
    height: 100%;
}

#welcome-title {
    color: $color-accent;
    text-style: bold;
    text-align: center;
    margin-bottom: 1;
}

.user-input {
    margin-bottom: 1;
    width: 40;
}


.user-input:focus {
    border: tall $color-accent;
} 

/* Main Layout */
#grid {
    layout: grid;
    /* grid-size: <columns> <rows> */
    grid-size: 2 1;
    margin-bottom: 0;
    height: 11;
}

Static {
    content-align: center middle;
}

/* Content Areas */
.panel {
    padding: 1 1;
    border: round $color-border;
    background: $color-surface;
    height: 100%;
    width: 100%;
    margin: 0;
    box-sizing: border-box;
    content-align-horizontal: center;
    content-align-vertical: middle;
    text-align: center;
}

#command-history {
    content-align: left top;
    height: 1fr;
    width: 100%;
    margin-left: 0;
    margin-right: 0;
    border: round $color-border;
    background: $color-surface;
}

#output {
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    background: transparent;
    padding: 1 2; /* 1 row top/bottom, 2 columns left/right */
}

/* Timer */
MyTimerBox {
    height: 1;
    margin-bottom: 1;
}

#spacer {
    width: 1fr;
    background: transparent;
}

Clock {
    background: $color-orange;
    width: auto;
}

#time-display {
    background: $color-orange;
    width: auto;
}

/* Input Components */
.input-text {
    border: round $color-border;
	background: $color-surface;
    margin-bottom: 1;
}

.input-text:focus, .input-text.-valid:focus, .input-text.-invalid:focus {
    border: round $color-accent; /* Claude-like soft amber focus */
	background: transparent;
	background-tint: transparent;
}

/* Utilities */
#error {
    color: $color-error;
    text-style: bold;
}
